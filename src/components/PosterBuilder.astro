---
const iconBaseUrl = 'https://api.iconify.design/lucide';
const widgetButtons = [
  ['text', 'Texto libre', 'type'],
  ['qr', 'URL / QR', 'qr-code'],
  ['datetime', 'Fecha y hora', 'clock-3'],
  ['image', 'Imagen', 'image'],
  ['weather', 'Tiempo', 'sun-cloud'],
  ['forecast', 'Previsión', 'cloud-sun'],
];
const iconUrl = (icon: string) => `${iconBaseUrl}/${icon}.svg`;
---

<section class="poster-app" data-poster-builder>
  <header class="poster-hero poster-hero-compact">
    <div>
      <p class="poster-kicker">Digital Signage</p>
      <h1>Editor visual de pantallas</h1>
      <p>Inserta widgets, configura la pantalla y copia la URL para abrirla en la televisión.</p>
    </div>
    <div class="poster-actions" aria-label="Acciones de configuración">
      <button type="button" data-export><img class="toolbar-icon" src={iconUrl('file-down')} alt="" loading="lazy" /> Exportar JSON</button>
      <button type="button" data-import><img class="toolbar-icon" src={iconUrl('file-up')} alt="" loading="lazy" /> Importar JSON</button>
      <button type="button" class="danger" data-reset><img class="toolbar-icon" src={iconUrl('rotate-ccw')} alt="" loading="lazy" /> Resetear</button>
    </div>
  </header>

  <section class="widget-toolbar" aria-labelledby="widget-toolbar-title">
    <div>
      <p class="poster-kicker" id="widget-toolbar-title">Barra de herramientas</p>
      <h2>Insertar widgets</h2>
    </div>
    <div class="widget-palette" role="toolbar" aria-label="Insertar widgets">
      {widgetButtons.map(([type, label, icon]) => (
        <button type="button" data-add-widget={type} title={label} aria-label={`Insertar ${label}`}>
          <img class="toolbar-icon" src={iconUrl(icon)} alt="" loading="lazy" />
          <span>{label}</span>
        </button>
      ))}
    </div>
  </section>

  <div class="poster-layout">
    <main class="poster-editor-main">
      <section class="poster-workspace" aria-labelledby="preview-title">
        <div class="panel-heading">
          <div>
            <p class="poster-kicker">Visualización</p>
            <h2 id="preview-title">Pantalla</h2>
          </div>
          <span class="screen-ratio">16:9</span>
        </div>
        <div class="screen-shell">
          <div class="poster-screen" data-editor-screen></div>
        </div>
      </section>

      <aside class="poster-panel inspector" aria-labelledby="inspector-title">
        <div class="panel-heading">
          <div>
            <p class="poster-kicker">Configuración</p>
            <h2 id="inspector-title">Widget seleccionado</h2>
          </div>
        </div>
        <div data-inspector aria-live="polite"></div>
      </aside>
    </main>

    <aside class="poster-panel page-panel" aria-labelledby="pages-title">
      <div class="panel-heading">
        <div>
          <p class="poster-kicker">Listado</p>
          <h2 id="pages-title">Páginas</h2>
        </div>
        <button type="button" data-add-page aria-label="Añadir página"><img class="toolbar-icon" src={iconUrl('plus')} alt="" loading="lazy" /> Añadir</button>
      </div>
      <div class="page-list" data-page-list></div>
      <label class="share-url">
        <span>URL para la televisión</span>
        <input data-share-url readonly />
      </label>
      <label class="json-box">
        <span>Configuración JSON</span>
        <textarea data-json rows="8" placeholder="Pulsa exportar JSON para copiar la configuración o pega aquí una configuración para importarla."></textarea>
      </label>
    </aside>
  </div>
</section>

<script>
  import '../scripts/poster-runtime.js';
</script>
